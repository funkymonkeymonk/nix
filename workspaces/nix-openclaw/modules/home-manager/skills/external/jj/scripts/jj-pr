#!/usr/bin/env bash
# jj-pr: Create a new PR with conventional branch naming
# Usage: jj-pr <type> <description> [commit-message]
# Example: jj-pr feat user-auth "Add user authentication flow"

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/jj-workspace-lib"

usage() {
    cat <<EOF
Usage: jj-pr <type> <description> [commit-message]

Create a new PR with conventional branch naming.
Works in jj workspaces (including child workspaces separate from the parent repo).

Types:
  feat, feature  - New features
  fix, bugfix    - Bug fixes
  hotfix         - Urgent fixes
  release        - Release preparation
  chore          - Non-code tasks (deps, docs)

Arguments:
  type           - Branch type prefix
  description    - Branch description (kebab-case)
  commit-message - Optional commit message (uses description if not provided)

Examples:
  jj-pr feat user-auth "Add user authentication flow"
  jj-pr fix null-pointer
  jj-pr chore deps-update "Update dependencies to latest versions"
EOF
    exit 1
}

# Validate type
validate_type() {
    local type="$1"
    case "$type" in
        feat|feature|fix|bugfix|hotfix|release|chore)
            return 0
            ;;
        *)
            echo -e "${JJ_RED}Error: Invalid type '$type'${JJ_NC}"
            echo "Valid types: feat, feature, fix, bugfix, hotfix, release, chore"
            exit 1
            ;;
    esac
}

# Normalize type (feature -> feat, bugfix -> fix)
normalize_type() {
    local type="$1"
    case "$type" in
        feature) echo "feat" ;;
        bugfix) echo "fix" ;;
        *) echo "$type" ;;
    esac
}

# Validate description (kebab-case, no special chars)
validate_description() {
    local desc="$1"
    if [[ ! "$desc" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
        echo -e "${JJ_RED}Error: Description must be kebab-case (lowercase, hyphens only)${JJ_NC}"
        echo "Got: $desc"
        echo "Example: user-auth, fix-null-pointer, gh-123-add-feature"
        exit 1
    fi
}

# Main
if [[ $# -lt 2 ]]; then
    usage
fi

TYPE="$1"
DESC="$2"
MESSAGE="${3:-$DESC}"

validate_type "$TYPE"
validate_description "$DESC"

TYPE=$(normalize_type "$TYPE")
BRANCH="${TYPE}/${DESC}"

# Check we're in a jj repo
if ! jj_in_repo; then
    echo -e "${JJ_RED}Error: Not in a jj repository${JJ_NC}"
    exit 1
fi

# Get GitHub repo
GH_REPO=$(jj_get_gh_repo)

echo -e "${JJ_YELLOW}Creating PR with branch: ${BRANCH}${JJ_NC}"
echo -e "GitHub repo: ${JJ_BLUE}${GH_REPO}${JJ_NC}"

# Check current state
echo -e "\n${JJ_GREEN}1. Checking status...${JJ_NC}"
jj status

# Check if we have changes
if jj diff --stat | grep -q .; then
    echo -e "\n${JJ_GREEN}2. Changes detected in working copy${JJ_NC}"
else
    echo -e "\n${JJ_YELLOW}Warning: No changes in working copy${JJ_NC}"
    read -p "Continue anyway? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# Describe the commit
echo -e "\n${JJ_GREEN}3. Setting commit message...${JJ_NC}"
jj describe -m "$MESSAGE"

# Create bookmark
echo -e "\n${JJ_GREEN}4. Creating bookmark: ${BRANCH}${JJ_NC}"
jj bookmark set "$BRANCH" -r @

# Push to remote
echo -e "\n${JJ_GREEN}5. Pushing to remote...${JJ_NC}"
jj_push_bookmark "$BRANCH" true

# Create PR
echo -e "\n${JJ_GREEN}6. Creating PR...${JJ_NC}"
jj_create_pr "$GH_REPO" "$BRANCH"

PR_URL=$(jj_get_pr_url "$GH_REPO" "$BRANCH")
echo -e "\n${JJ_GREEN}Done! PR created: ${JJ_BLUE}${PR_URL}${JJ_NC}"
