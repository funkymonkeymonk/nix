{
  "name": "nixos-flake-installer",
  "version": "0.1.0",
  "description": "Interactive NixOS installer with TUI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nixos-flake-installer": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.tsx --outdir ./dist --target node",
    "start": "bun run dist/index.js",
    "dev": "bun run --watch src/index.tsx"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "ink-text-input": "^5.0.1",
    "ink-select-input": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "keywords": ["nixos", "installer", "tui", "bun"],
  "license": "MIT"
}
