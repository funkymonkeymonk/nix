#!/usr/bin/env bash
#
# fjj - Fast Jujutsu Workflow
# Universal workspace management with GitHub mirrors
#

set -euo pipefail

# Configuration
MIRROR_ROOT="/srv/github"
WORKSPACE_ROOT="$HOME/workspaces"
MAX_STACK_DEPTH=3

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging (all go to stderr so stdout is clean for returns)
log_info() { echo -e "${BLUE}ℹ${NC} $1" >&2; }
log_success() { echo -e "${GREEN}✓${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}⚠${NC} $1" >&2; }
log_error() { echo -e "${RED}✗${NC} $1" >&2; }

# Detect current repository from git remote
detect_current_repo() {
    local dir="${1:-$(pwd)}"
    if [ -d "$dir/.git" ] || [ -d "$dir/.jj" ]; then
        local remote
        remote=$(cd "$dir" && git remote get-url origin 2>/dev/null | sed 's/.*github.com[:/]\([^/]*\/[^/]*\)\.git$/\1/' || true)
        if [ -n "$remote" ]; then
            echo "$remote"
            return 0
        fi
    fi
    return 1
}

# Get repo name from full path
get_repo_name() {
    local repo_path="$1"
    basename "$repo_path"
}

# Check if mirror exists
mirror_exists() {
    local repo="$1"
    [ -d "$MIRROR_ROOT/$repo/.git" ] || [ -d "$MIRROR_ROOT/$repo/.jj" ]
}

# Ensure mirror exists, create if not
ensure_mirror() {
    local repo="$1"
    local mirror_path="$MIRROR_ROOT/$repo"
    
    if ! mirror_exists "$repo"; then
        log_info "Mirror not found: $repo"
        log_info "Cloning to $mirror_path..."
        
        mkdir -p "$(dirname "$mirror_path")"
        gh repo clone "$repo" "$mirror_path" || {
            log_error "Failed to clone $repo"
            return 1
        }
        
        # Setup jj mirror if needed
        if [ ! -d "$mirror_path/.jj" ]; then
            (cd "$mirror_path" && jj git init --colocate 2>/dev/null || true)
        fi
        
        log_success "Mirror created: $repo"
    fi
    
    echo "$mirror_path"
}

# Generate workspace name
generate_workspace_name() {
    local repo="$1"
    local branch="$2"
    local date_str=$(date +%Y%m%d)
    local id=$(openssl rand -hex 2 | cut -c1-4)
    local repo_name=$(get_repo_name "$repo")
    local branch_clean=$(echo "$branch" | tr '/' '-')
    
    echo "${repo_name}-${branch_clean}-${date_str}-${id}"
}

# Find existing workspace
find_existing_workspace() {
    local repo="$1"
    local branch="$2"
    local repo_name=$(get_repo_name "$repo")
    local branch_clean=$(echo "$branch" | tr '/' '-')
    
    # Look for workspace matching pattern
    local pattern="${WORKSPACE_ROOT}/${repo_name}-${branch_clean}-*"
    local workspaces=( $pattern )
    
    if [ -d "${workspaces[0]}" ]; then
        echo "${workspaces[0]}"
        return 0
    fi
    return 1
}

# Create workspace from mirror
create_workspace() {
    local repo="$1"
    local branch="$2"
    local mirror_path="$3"
    
    local workspace_name=$(generate_workspace_name "$repo" "$branch")
    local workspace_path="$WORKSPACE_ROOT/$workspace_name"
    
    mkdir -p "$WORKSPACE_ROOT"
    
    log_info "Creating workspace: $workspace_name"
    
    # Create jj workspace from mirror (redirect all output to stderr)
    if ! (cd "$mirror_path" && jj workspace add "$workspace_path" 1>&2); then
        log_error "Failed to create workspace"
        return 1
    fi
    
    # Setup the branch (redirect to stderr)
    (cd "$workspace_path" && jj bookmark create "$branch" -r @ 1>&2 2>/dev/null || true)
    
    # Add to zoxide
    zoxide add "$workspace_path" 2>/dev/null || true
    
    log_success "Created workspace: $workspace_name"
    echo "$workspace_path"
}

# Interactive repo selection with fzf
select_repo_fzf() {
    local header="Select repository (Tab:multi, Enter:confirm):"
    
    # Build list of available mirrors
    local mirrors=()
    if [ -d "$MIRROR_ROOT" ]; then
        while IFS= read -r -d '' mirror; do
            local repo_name=$(basename "$mirror")
            local owner=$(basename "$(dirname "$mirror")")
            local full_name="${owner}/${repo_name}"
            
            # Get last update time
            local last_update=$(cd "$mirror" && git log -1 --format=%cd --date=relative 2>/dev/null || echo "unknown")
            mirrors+=("${full_name}|${last_update}")
        done < <(find "$MIRROR_ROOT" -mindepth 2 -maxdepth 2 -type d -print0 2>/dev/null)
    fi
    
    if [ ${#mirrors[@]} -eq 0 ]; then
        log_error "No mirrors found. Run 'fjj --add' first."
        return 1
    fi
    
    # Format for fzf
    printf '%s\n' "${mirrors[@]}" | \
        column -t -s '|' | \
        fzf --header="$header" \
            --preview "cd $MIRROR_ROOT/{1} && git log --oneline -5 2>/dev/null || echo 'No git history'" \
            --preview-window=right:50% | \
        awk '{print $1}'
}

# Interactive branch selection
select_branch_fzf() {
    local repo_path="$1"
    local header="Select branch, remote branch, or type new name (conventional: feat/, fix/, chore/, hotfix/):"
    
    (cd "$repo_path" && {
        echo "=== Local Bookmarks ==="
        jj bookmark list -a 2>/dev/null | grep -v '^@' | awk '{print $1}' | grep -v '^$' || true
        
        echo ""
        echo "=== Remote Branches ==="
        git branch -r 2>/dev/null | grep -v 'HEAD' | sed 's/origin\///' | awk '{print $1}' | sort -u || true
        
        echo ""
        echo "[create new branch]"
    }) | fzf --header="$header" --print-query | tail -1
}

# Add repos to mirrors
interactive_add() {
    log_info "Discovering repositories..."
    
    # Build combined list from multiple sources
    local repos=()
    
    # 1. User's repos
    if gh auth status >/dev/null 2>&1; then
        log_info "Fetching your repositories..."
        while IFS= read -r repo; do
            repos+=("[yours] $repo")
        done < <(gh repo list --limit 100 --json nameWithOwner --jq '.[].nameWithOwner' 2>/dev/null || true)
        
        # 2. Org repos
        log_info "Fetching organization repositories..."
        while IFS= read -r org; do
            while IFS= read -r repo; do
                repos+=("[org:$org] $repo")
            done < <(gh repo list "$org" --limit 50 --json nameWithOwner --jq '.[].nameWithOwner' 2>/dev/null || true)
        done < <(gh org list --json login --jq '.[].login' 2>/dev/null || true)
        
        # 3. Starred repos
        log_info "Fetching starred repositories..."
        while IFS= read -r repo; do
            repos+=("[starred] $repo")
        done < <(gh api user/starred --jq '.[].full_name' 2>/dev/null || true)
    fi
    
    if [ ${#repos[@]} -eq 0 ]; then
        log_warn "No repositories found. Make sure you're authenticated with 'gh auth login'"
        log_info "You can still add public repos by typing 'owner/repo'"
    fi
    
    # Add manual entry option
    repos+=("[manual] Type owner/repo...")
    
    # Show fzf selector
    local selected=$(printf '%s\n' "${repos[@]}" | \
        fzf --multi \
            --header="Tab:select multiple, Enter:clone to mirror" \
            --preview "echo {} | grep -oE '[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$' | head -1 | xargs -I [] gh repo view [] --json description,updatedAt,stargazersCount --template '{{.description}}\n⭐ {{.stargazersCount}} | Updated: {{.updatedAt}}' 2>/dev/null || echo 'Preview not available'" \
            --preview-window=right:50%)
    
    if [ -z "$selected" ]; then
        return 0
    fi
    
    # Process selections
    echo "$selected" | while IFS= read -r line; do
        # Extract repo name
        local repo=$(echo "$line" | grep -oE '[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$' | head -1)
        
        if [ "$line" == "[manual] Type owner/repo..." ]; then
            echo -n "Enter owner/repo: "
            read -r repo
        fi
        
        if [ -n "$repo" ]; then
            ensure_mirror "$repo" || true
        fi
    done
}

# Quick add specific repo
quick_add() {
    local repo="$1"
    ensure_mirror "$repo"
}

# List all workspaces
cmd_list() {
    if [ ! -d "$WORKSPACE_ROOT" ]; then
        log_warn "No workspaces found"
        return 0
    fi
    
    local workspaces=()
    while IFS= read -r -d '' ws; do
        local name=$(basename "$ws")
        local repo=$(detect_current_repo "$ws" 2>/dev/null || echo "unknown")
        local last=$(stat -c %Y "$ws" 2>/dev/null || stat -f %m "$ws" 2>/dev/null)
        local age=$(( ($(date +%s) - last) / 86400 ))
        
        workspaces+=("${name}|${repo}|${age}d ago")
    done < <(find "$WORKSPACE_ROOT" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
    
    if [ ${#workspaces[@]} -eq 0 ]; then
        log_warn "No workspaces found"
        return 0
    fi
    
    printf '%s\n' "${workspaces[@]}" | column -t -s '|'
}

# Clean merged workspaces
cmd_clean() {
    log_info "Checking for merged workspaces..."

    local cleaned=0
    while IFS= read -r -d '' ws; do
        local name=$(basename "$ws")

        # Check if workspace has merged PR
        (cd "$ws" && {
            # Get the bookmark at @ - jj bookmark list -r @ outputs "bookmarkname: ..."
            # The first line contains the active bookmark
            local current_branch
            current_branch=$(jj bookmark list -r @ 2>/dev/null | head -1 | awk '{print $1}' | tr -d ':' || true)

            if [ -n "$current_branch" ]; then
                # Get repo from mirror since workspaces don't have .git directories
                # The workspace's .jj/repo/repo file contains the path to the parent repo
                local repo=""
                local parent_path=""

                # Try to get the parent repo path from jj config
                if [ -f .jj/repo/repo ]; then
                    parent_path=$(grep '^path=' .jj/repo/repo 2>/dev/null | cut -d'=' -f2 || true)
                fi

                # If we found a parent path, get the repo from it
                if [ -n "$parent_path" ] && [ -d "$parent_path/.git" ]; then
                    repo=$(cd "$parent_path" && git remote get-url origin 2>/dev/null | sed 's/.*github.com[:/]\([^/]*\/[^/]*\)\.git$/\1/' || true)
                fi

                if [ -n "$repo" ]; then
                    local state
                    state=$(gh pr view "$current_branch" --json state --jq '.state' 2>/dev/null || echo "")
                    if [ "$state" == "MERGED" ]; then
                        log_info "Removing merged workspace: $name (branch: $current_branch)"
                        # Remove the workspace from jj first, then delete the directory
                        jj workspace forget "$ws" 2>/dev/null || true
                        rm -rf "$ws"
                        ((cleaned++))
                    elif [ "$state" == "CLOSED" ]; then
                        log_info "Removing closed workspace: $name (branch: $current_branch)"
                        jj workspace forget "$ws" 2>/dev/null || true
                        rm -rf "$ws"
                        ((cleaned++))
                    fi
                else
                    log_warn "Could not detect repo for workspace: $name"
                fi
            else
                log_warn "No bookmark found at @ for workspace: $name"
            fi
        }) || true
    done < <(find "$WORKSPACE_ROOT" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

    log_success "Cleaned $cleaned workspaces"
}

# Show status
cmd_status() {
    log_info "Mirror Status:"
    if [ -d "$MIRROR_ROOT" ]; then
        local count=$(find "$MIRROR_ROOT" -mindepth 2 -maxdepth 2 -type d 2>/dev/null | wc -l)
        echo "  Mirrors: $count repositories"
        echo "  Location: $MIRROR_ROOT"
    else
        echo "  No mirrors configured"
    fi
    
    echo ""
    log_info "Workspace Status:"
    if [ -d "$WORKSPACE_ROOT" ]; then
        local count=$(find "$WORKSPACE_ROOT" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
        echo "  Active workspaces: $count"
        echo "  Location: $WORKSPACE_ROOT"
    else
        echo "  No workspaces"
    fi
}

# Main workspace entry
cmd_workspace() {
    local branch="${1:-}"
    local explicit_repo="${2:-}"
    
    # Detect current context
    local current_repo=""
    local current_workspace=""
    
    if [ -d "$PWD/.jj" ] || [ -d "$PWD/.git" ]; then
        current_repo=$(detect_current_repo)
        if [[ "$PWD" == "$WORKSPACE_ROOT"* ]]; then
            current_workspace="$PWD"
        fi
    fi
    
    # Determine target repo
    local target_repo=""
    if [ -n "$explicit_repo" ]; then
        target_repo="$explicit_repo"
    elif [ -n "$current_repo" ] && [ -z "$branch" ]; then
        # In workspace without args - interactive mode
        target_repo=$(select_repo_fzf)
        [ -z "$target_repo" ] && return 0
    elif [ -n "$current_repo" ]; then
        # In workspace with branch arg - stay in same repo
        target_repo="$current_repo"
    else
        # Fresh start - interactive
        target_repo=$(select_repo_fzf)
        [ -z "$target_repo" ] && return 0
    fi
    
    # Ensure mirror exists
    local mirror_path=$(ensure_mirror "$target_repo")
    [ -z "$mirror_path" ] && return 1
    
    # Determine branch
    local target_branch=""
    if [ -n "$branch" ]; then
        target_branch="$branch"
    else
        target_branch=$(select_branch_fzf "$mirror_path")
        [ "$target_branch" == "[create new branch]" ] && target_branch=""
        
        if [ -z "$target_branch" ]; then
            echo -n "Enter branch name (e.g., feat/my-feature): "
            read -r target_branch
        fi
    fi
    
    [ -z "$target_branch" ] && return 0
    
    # Check for existing workspace
    local existing=$(find_existing_workspace "$target_repo" "$target_branch")
    if [ -n "$existing" ]; then
        log_success "Using existing workspace: $(basename "$existing")"
        echo "$existing"  # Output path for parent shell to cd
        return 0
    fi
    
    # Create new workspace
    local workspace_path
    workspace_path=$(create_workspace "$target_repo" "$target_branch" "$mirror_path")
    if [ $? -eq 0 ] && [ -n "$workspace_path" ]; then
        echo "$workspace_path"  # Output path for parent shell to cd
    else
        return 1
    fi
}

# Help
cmd_help() {
    cat << 'EOF'
Usage: fjj [command] [args]

Fast Jujutsu Workflow - Universal workspace management

Commands:
  fjj [branch] [repo]     Create/goto workspace (smart context-aware)
  fjj --add [owner/repo]  Add repositories to mirrors
  fjj --list              List all workspaces
  fjj --clean             Remove merged workspaces
  fjj --status            Show mirror and workspace status
  fjj --help              Show this help

Workflow:
  1. fjj --add            # Add your repos to /srv/github/
  2. fjj                  # Interactive: select repo → select/create branch
  3. work...              # Do work in workspace
  4. fjj --clean          # Clean up merged workspaces

Examples:
  fjj                          # Interactive mode
  fjj feat/new-ui              # Create workspace feat/new-ui in current repo
  fjj fix/bug nixpkgs          # Create workspace in nixpkgs repo
  fjj --add nixos/nixpkgs      # Quick add public repo

Environment:
  MIRROR_ROOT=/srv/github      # Where mirrors are stored
  WORKSPACE_ROOT=~/workspaces  # Where workspaces are created

EOF
}

# Main
case "${1:-}" in
    --add|-a)
        shift
        if [ $# -eq 0 ]; then
            interactive_add
        else
            quick_add "$1"
        fi
        ;;
    --list|-l)
        cmd_list
        ;;
    --clean|-c)
        cmd_clean
        ;;
    --status|-s)
        cmd_status
        ;;
    --help|-h)
        cmd_help
        ;;
    "")
        # Interactive mode when no args provided
        cmd_workspace
        ;;
    -*)
        log_error "Unknown option: $1"
        cmd_help
        exit 1
        ;;
    *)
        # Workspace mode: fjj [branch] [repo]
        cmd_workspace "$@"
        ;;
esac