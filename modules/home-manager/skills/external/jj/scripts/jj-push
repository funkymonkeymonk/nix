#!/usr/bin/env bash
# jj-push: Push bookmark to origin
# Usage: jj-push [--dry-run] [bookmark]
# Example: jj-push feat/my-feature

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/jj-workspace-lib"

# Parse arguments
DRY_RUN=false
BOOKMARK=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            cat <<'EOF'
Usage: jj-push [--dry-run] [bookmark]

Push bookmark to origin. If no bookmark specified, uses current bookmark.

Options:
  --dry-run         Show what would be done without doing it
  -h, --help        Show this help

Examples:
  jj-push                    # Push current bookmark
  jj-push feat/my-feature    # Push specific bookmark
  jj-push --dry-run          # Preview push without executing
EOF
            exit 0
            ;;
        -*)
            echo -e "${JJ_RED}Unknown option: $1${JJ_NC}"
            exit 1
            ;;
        *)
            BOOKMARK="$1"
            shift
            ;;
    esac
done

# Check we're in a jj repo
if ! jj_in_repo; then
    echo -e "${JJ_RED}Error: Not in a jj repository${JJ_NC}"
    exit 1
fi

# Get bookmark if not provided
if [[ -z "$BOOKMARK" ]]; then
    BOOKMARK=$(jj_get_current_bookmark)
    if [[ -z "$BOOKMARK" ]]; then
        echo -e "${JJ_RED}Error: No bookmark found on current commit${JJ_NC}"
        echo "Create a bookmark first with: jj bookmark set <name> -r @"
        exit 1
    fi
fi

# Get GitHub repo
GH_REPO=$(jj_get_gh_repo)
echo -e "Repository: ${JJ_BLUE}${GH_REPO}${JJ_NC}"
echo -e "Bookmark: ${JJ_YELLOW}${BOOKMARK}${JJ_NC}"

if [[ "$DRY_RUN" == true ]]; then
    echo -e "${JJ_YELLOW}[DRY RUN] Would push bookmark: ${BOOKMARK}${JJ_NC}"
    echo -e "${JJ_GREEN}Dry run complete - no changes made${JJ_NC}"
    exit 0
fi

# Push to origin
echo -e "${JJ_GREEN}Pushing bookmark...${JJ_NC}"
jj_push_bookmark "$BOOKMARK"

echo -e "${JJ_GREEN}Push complete: ${BOOKMARK}${JJ_NC}"
