#!/usr/bin/env bash
# jj-sync: Fetch latest and rebase current work onto main
# Usage: jj-sync [base-branch]
# Example: jj-sync main

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/jj-workspace-lib"

usage() {
    cat <<EOF
Usage: jj-sync [base-branch]

Fetch latest from remote and rebase current work onto base branch.
Works in jj workspaces (including child workspaces separate from the parent repo).

This script:
1. Fetches latest from remote
2. Rebases current commit (or stack) onto base branch
3. Shows the new state

Arguments:
  base-branch - Branch to rebase onto (default: main)

Examples:
  jj-sync              # Rebase onto main
  jj-sync develop      # Rebase onto develop
EOF
    exit 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
fi

BASE="${1:-main}"

# Check we're in a jj repo
if ! jj_in_repo; then
    echo -e "${JJ_RED}Error: Not in a jj repository${JJ_NC}"
    exit 1
fi

echo -e "${JJ_YELLOW}Syncing with ${BASE}...${JJ_NC}"

# Show current state
echo -e "\n${JJ_GREEN}1. Current state:${JJ_NC}"
jj log -r '@-::@' --no-graph

# Fetch latest
echo -e "\n${JJ_GREEN}2. Fetching from remote...${JJ_NC}"
jj git fetch

# Check if we're already on base
CURRENT_PARENT=$(jj log -r '@-' --no-graph -T 'change_id' 2>/dev/null || echo "")
BASE_ID=$(jj log -r "$BASE" --no-graph -T 'change_id' 2>/dev/null || echo "")

if [[ "$CURRENT_PARENT" == "$BASE_ID" ]]; then
    echo -e "\n${JJ_GREEN}Already up to date with ${BASE}${JJ_NC}"
else
    # Rebase onto base
    echo -e "\n${JJ_GREEN}3. Rebasing onto ${BASE}...${JJ_NC}"
    jj rebase -r @ -d "$BASE"
fi

# Show new state
echo -e "\n${JJ_GREEN}4. New state:${JJ_NC}"
jj log -r "${BASE}::@" --no-graph

# Check if push is needed
if jj log -r '@' --no-graph | grep -q '\*'; then
    echo -e "\n${JJ_YELLOW}Note: Bookmark needs pushing (marked with *)${JJ_NC}"
    echo "Run 'jj git push' to update remote"
fi

echo -e "\n${JJ_GREEN}Done! Synced with ${BASE}${JJ_NC}"
