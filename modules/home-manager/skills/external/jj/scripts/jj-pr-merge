#!/usr/bin/env bash
# jj-pr-merge: Merge a pull request
# Usage: jj-pr-merge [--method squash|merge|rebase] [--auto] [--dry-run] [branch]
# Example: jj-pr-merge --method squash feat/my-feature

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/jj-workspace-lib"

# Parse arguments
MERGE_METHOD="squash"
AUTO_MERGE=false
DRY_RUN=false
BRANCH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --method)
            MERGE_METHOD="$2"
            shift 2
            ;;
        --auto)
            AUTO_MERGE=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            cat <<'EOF'
Usage: jj-pr-merge [--method squash|merge|rebase] [--auto] [--dry-run] [branch]

Merge a pull request. If no branch specified, uses current bookmark.

Options:
  --method METHOD   Merge method: squash (default), merge, or rebase
  --auto            Configure auto-merge instead of merging immediately
  --dry-run         Show what would be done without doing it
  -h, --help        Show this help

Examples:
  jj-pr-merge                    # Merge current branch with squash
  jj-pr-merge feat/my-feature    # Merge specific branch
  jj-pr-merge --method rebase    # Use rebase merge
  jj-pr-merge --auto             # Configure auto-merge
  jj-pr-merge --dry-run          # Preview merge without executing
EOF
            exit 0
            ;;
        -*)
            echo -e "${JJ_RED}Unknown option: $1${JJ_NC}"
            exit 1
            ;;
        *)
            BRANCH="$1"
            shift
            ;;
    esac
done

# Check we're in a jj repo
if ! jj_in_repo; then
    echo -e "${JJ_RED}Error: Not in a jj repository${JJ_NC}"
    exit 1
fi

# Get GitHub repo
GH_REPO=$(jj_get_gh_repo)

# Get branch if not provided
if [[ -z "$BRANCH" ]]; then
    BRANCH=$(jj_get_current_bookmark)
    if [[ -z "$BRANCH" ]]; then
        echo -e "${JJ_RED}Error: No bookmark found on current commit${JJ_NC}"
        echo "Specify a branch or create a bookmark"
        exit 1
    fi
fi

# Get PR info
PR_NUMBER=$(jj_get_pr_number "$GH_REPO" "$BRANCH")
if [[ -z "$PR_NUMBER" ]]; then
    echo -e "${JJ_RED}Error: No PR found for branch '$BRANCH'${JJ_NC}"
    exit 1
fi

PR_URL=$(jj_get_pr_url "$GH_REPO" "$BRANCH")

echo -e "Repository: ${JJ_BLUE}${GH_REPO}${JJ_NC}"
echo -e "Branch: ${JJ_YELLOW}${BRANCH}${JJ_NC}"
echo -e "PR: #${PR_NUMBER}${JJ_NC}"
echo -e "URL: ${JJ_BLUE}${PR_URL}${JJ_NC}"
echo -e "Method: ${JJ_YELLOW}${MERGE_METHOD}${JJ_NC}"

if [[ "$AUTO_MERGE" == true ]]; then
    echo -e "Mode: ${JJ_YELLOW}Auto-merge (will merge when checks pass)${JJ_NC}"
fi

if [[ "$DRY_RUN" == true ]]; then
    echo -e "${JJ_YELLOW}[DRY RUN] Would merge PR #${PR_NUMBER}${JJ_NC}"
    if [[ "$AUTO_MERGE" == true ]]; then
        echo -e "${JJ_YELLOW}[DRY RUN] Configure auto-merge with --${MERGE_METHOD}${JJ_NC}"
    else
        echo -e "${JJ_YELLOW}[DRY RUN] Merge immediately with --${MERGE_METHOD}${JJ_NC}"
    fi
    echo -e "${JJ_GREEN}Dry run complete - no changes made${JJ_NC}"
    exit 0
fi

# Merge or configure auto-merge
if [[ "$AUTO_MERGE" == true ]]; then
    echo -e "${JJ_GREEN}Configuring auto-merge for PR #${PR_NUMBER}...${JJ_NC}"
    gh pr merge --repo "$GH_REPO" "$BRANCH" --"$MERGE_METHOD" --auto
    echo -e "${JJ_GREEN}Auto-merge configured! PR will merge when checks pass.${JJ_NC}"
else
    echo -e "${JJ_GREEN}Merging PR #${PR_NUMBER}...${JJ_NC}"
    jj_merge_pr "$GH_REPO" "$BRANCH" "$MERGE_METHOD"
    echo -e "${JJ_GREEN}PR merged and branch deleted!${JJ_NC}"
fi
