#!/usr/bin/env bash
# microvm - Manage MicroVM definitions in Nix format
# Usage: microvm [command] [args]
#
# Commands:
#   init                    Initialize microvm configuration
#   add <name> [options]    Add a new MicroVM
#   remove <name>           Remove a MicroVM
#   list                    List all MicroVMs
#   generate                Generate Nix configuration
#   edit <name>             Edit a MicroVM definition
#
# Examples:
#   sudo microvm init
#   sudo microvm add openclaw --ip 192.168.83.16 --role opencode
#   sudo microvm add matrix --ip 192.168.83.15 --flake github:funkymonkeymonk/nix#microvm.nixosConfigurations.matrix
#   microvm list
#   sudo microvm remove openclaw
#   sudo microvm generate

set -e

# Configuration
NIX_FILE="${MICROVM_NIX_FILE:-/etc/nixos/microvms.nix}"
MICROVM_DIR="$(dirname "$NIX_FILE")"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log_info() {
  echo -e "${BLUE}INFO:${NC} $1"
}

log_success() {
  echo -e "${GREEN}SUCCESS:${NC} $1"
}

log_error() {
  echo -e "${RED}ERROR:${NC} $1" >&2
}

log_warn() {
  echo -e "${YELLOW}WARN:${NC} $1"
}

log_debug() {
  [[ "${MICROVM_DEBUG:-}" == "1" ]] && echo -e "${CYAN}DEBUG:${NC} $1"
}

# Check if running as root (needed for writing config)
check_root() {
  if [[ $EUID -ne 0 ]]; then
    log_error "This command requires root privileges. Run with sudo."
    exit 1
  fi
}

# Generate MAC address from VM name
generate_mac() {
  local name="$1"
  local mac_hash
  mac_hash=$(echo -n "$name" | sha256sum | cut -c1-10)
  echo "02:${mac_hash:0:2}:${mac_hash:2:2}:${mac_hash:4:2}:${mac_hash:6:2}:${mac_hash:8:2}"
}

# Generate IP from last octet (if provided as number)
generate_ip() {
  local last_octet="$1"
  echo "192.168.83.${last_octet}"
}

# Check if nix file exists and is valid
validate_nix_file() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    return 1
  fi
  # Try to parse with nix-instantiate --parse
  if ! nix-instantiate --parse "$file" >/dev/null 2>&1; then
    log_error "Invalid Nix syntax in $file"
    return 1
  fi
  return 0
}

# Initialize the microvm.nix file
cmd_init() {
  check_root
  
  if [[ -f "$NIX_FILE" ]]; then
    log_warn "MicroVM configuration already exists at $NIX_FILE"
    read -p "Overwrite? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      log_info "Cancelled."
      exit 0
    fi
  fi
  
  # Create directory if needed
  mkdir -p "$MICROVM_DIR"
  
  # Create initial Nix file
  cat > "$NIX_FILE" << 'NIXEOF'
# MicroVM definitions - managed by 'microvm' command
# DO NOT EDIT MANUALLY - use: sudo microvm add|remove|edit
{ config, lib, pkgs, ... }:
let
  cloudInitDir = "/var/lib/microvms/cloud-init";
  
  # Helper to generate MAC from name
  mkMac = name: let
    hash = builtins.substring 0 10 (builtins.hashString "sha256" name);
    hexToInt = h: 
      if h == "0" then 0 else if h == "1" then 1 else if h == "2" then 2 else if h == "3" then 3
      else if h == "4" then 4 else if h == "5" then 5 else if h == "6" then 6 else if h == "7" then 7
      else if h == "8" then 8 else if h == "9" then 9 else if h == "a" || h == "A" then 10
      else if h == "b" || h == "B" then 11 else if h == "c" || h == "C" then 12
      else if h == "d" || h == "D" then 13 else if h == "e" || h == "E" then 14
      else 15;
    bytes = map hexToInt (lib.stringToCharacters hash);
  in "02:${lib.concatMapStringsSep ":" (b: lib.fixedWidthString 2 "0" (lib.toHexString b)) (lib.take 5 bytes)}";
in {
  # MicroVM configurations will be added here by 'microvm add'
  microvm.vms = {
    # Example (remove after adding your own):
    # example = {
    #   flake = "github:funkymonkeymonk/nix#microvm.nixosConfigurations.example";
    #   interfaces = [{
    #     type = "tap";
    #     id = "microvm-example";
    #     mac = mkMac "example";
    #   }];
    #   hypervisor = pkgs.cloud-hypervisor;
    #   writableStoreOverlay = "/nix/.rw-store";
    #   shares = [
    #     { tag = "ro-store"; source = "/nix/store"; mountPoint = "/nix/.ro-store"; proto = "virtiofs"; }
    #     { tag = "cloud-init"; source = cloudInitDir; mountPoint = "/etc/cloud-init"; proto = "virtiofs"; }
    #   ];
    #   autostart = true;
    # };
  };
  
  # Per-VM cloud-init files (generated from VM names)
  environment.etc = lib.mkIf (config.microvm.vms != {}) (
    lib.mapAttrs' (name: vm: {
      name = "cloud-init/${name}.yaml";
      value = {
        text = ''
          #cloud-config
          hostname: ${name}
        '';
        mode = "0644";
      };
    }) config.microvm.vms
  );
  
  # Ensure cloud-init directory exists
  systemd.tmpfiles.rules = [
    "d ${cloudInitDir} 0755 root root -"
  ];
}
NIXEOF
  
  log_success "Initialized MicroVM configuration at $NIX_FILE"
  log_info "Next steps:"
  log_info "  1. Add your first MicroVM: sudo microvm add <name> --ip <ip>"
  log_info "  2. List MicroVMs: microvm list"
  log_info "  3. Import in your configuration: imports = [ ${NIX_FILE} ];"
}

# Parse arguments for 'add' command
cmd_add() {
  check_root
  
  if [[ $# -lt 1 ]]; then
    log_error "Usage: microvm add <name> [options]"
    log_info "Options:"
    log_info "  --ip <ip>           IP address (e.g., 192.168.83.16 or just 16)"
    log_info "  --flake <flake>     Flake reference (default: .#microvm.nixosConfigurations.<name>)"
    log_info "  --role <role>       Enable role (opencode, matrix, llm-host, etc.)"
    log_info "  --mac <mac>         Custom MAC address"
    log_info "  --no-autostart      Don't start on boot"
    log_info "  --memory <mb>       Memory in MB (default: 1024)"
    log_info "  --vcpus <n>         Number of vCPUs (default: 2)"
    exit 1
  fi
  
  local name="$1"
  shift
  
  # Validate name
  if [[ ! "$name" =~ ^[a-zA-Z][a-zA-Z0-9_-]*$ ]]; then
    log_error "Invalid MicroVM name: $name"
    log_info "Name must start with a letter and contain only alphanumeric, hyphen, and underscore"
    exit 1
  fi
  
  # Check if already exists
  if [[ -f "$NIX_FILE" ]] && grep -q "${name} = {" "$NIX_FILE" 2>/dev/null; then
    log_error "MicroVM '$name' already exists"
    log_info "Use 'microvm edit $name' to modify, or 'microvm remove $name' to remove first"
    exit 1
  fi
  
  # Default values
  local ip=""
  local flake=""
  local role=""
  local mac=""
  local autostart="true"
  local memory="1024"
  local vcpus="2"
  
  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ip)
        ip="$2"
        shift 2
        ;;
      --flake)
        flake="$2"
        shift 2
        ;;
      --role)
        role="$2"
        shift 2
        ;;
      --mac)
        mac="$2"
        shift 2
        ;;
      --no-autostart)
        autostart="false"
        shift
        ;;
      --memory)
        memory="$2"
        shift 2
        ;;
      --vcpus)
        vcpus="$2"
        shift 2
        ;;
      *)
        log_error "Unknown option: $1"
        exit 1
        ;;
    esac
  done
  
  # Auto-generate values if not provided
  if [[ -z "$ip" ]]; then
    # Try to find next available IP
    log_info "No IP specified, using automatic assignment"
    ip="auto"
  elif [[ "$ip" =~ ^[0-9]+$ ]]; then
    # Convert single number to full IP
    ip=$(generate_ip "$ip")
  fi
  
  if [[ -z "$flake" ]]; then
    flake=".#microvm.nixosConfigurations.${name}"
  fi
  
  if [[ -z "$mac" ]]; then
    mac=$(generate_mac "$name")
  fi
  
  log_debug "Adding MicroVM:"
  log_debug "  name: $name"
  log_debug "  ip: $ip"
  log_debug "  flake: $flake"
  log_debug "  mac: $mac"
  log_debug "  autostart: $autostart"
  
  # Initialize file if it doesn't exist
  if [[ ! -f "$NIX_FILE" ]]; then
    cmd_init
  fi
  
  # Generate VM config Nix expression
  local vm_config="    ${name} = {\n"
  vm_config+="      flake = \"${flake}\";\n"
  vm_config+="      interfaces = [\n"
  vm_config+="        {\n"
  vm_config+="          type = \"tap\";\n"
  vm_config+="          id = \"microvm-${name}\";\n"
  vm_config+="          mac = \"${mac}\";\n"
  vm_config+="        }\n"
  vm_config+="      ];\n"
  vm_config+="      hypervisor = pkgs.cloud-hypervisor;\n"
  vm_config+="      writableStoreOverlay = \"/nix/.rw-store\";\n"
  vm_config+="      shares = [\n"
  vm_config+="        {\n"
  vm_config+="          tag = \"ro-store\";\n"
  vm_config+="          source = \"/nix/store\";\n"
  vm_config+="          mountPoint = \"/nix/.ro-store\";\n"
  vm_config+="          proto = \"virtiofs\";\n"
  vm_config+="        }\n"
  vm_config+="        {\n"
  vm_config+="          tag = \"cloud-init\";\n"
  vm_config+="          source = cloudInitDir;\n"
  vm_config+="          mountPoint = \"/etc/cloud-init\";\n"
  vm_config+="          proto = \"virtiofs\";\n"
  vm_config+="        }\n"
  vm_config+="      ];\n"
  if [[ "$autostart" == "false" ]]; then
    vm_config+="      autostart = false;\n"
  fi
  vm_config+="    };"
  
  # Insert VM config into the file
  # Find the line with "microvm.vms = {" and add after it
  if grep -q "microvm.vms = {" "$NIX_FILE"; then
    # Use sed to insert after the opening brace
    # Handle both empty and non-empty cases
    if grep -A 1 "microvm.vms = {" "$NIX_FILE" | grep -q "# Example"; then
      # Replace the example comment with our config
      sed -i "/^    # Example.*remove after adding your own:/c\\${vm_config}" "$NIX_FILE"
    else
      # Insert after the opening brace (need to handle this carefully)
      # We'll create a new file with the content inserted
      local temp_file
      temp_file=$(mktemp)
      
      awk -v vm="$vm_config" '
        /^  microvm\.vms = \{/ {
          print
          print vm
          next
        }
        { print }
      ' "$NIX_FILE" > "$temp_file"
      
      mv "$temp_file" "$NIX_FILE"
    fi
    
    log_success "Added MicroVM '$name' to $NIX_FILE"
    log_info "Configuration:"
    log_info "  Name:     $name"
    log_info "  IP:       $ip"
    log_info "  MAC:      $mac"
    log_info "  Flake:    $flake"
    log_info "  Autostart: $autostart"
    
    # Validate the Nix file
    if nix-instantiate --parse "$NIX_FILE" >/dev/null 2>&1; then
      log_success "Nix syntax validated"
    else
      log_error "Generated invalid Nix syntax - please check $NIX_FILE"
      exit 1
    fi
    
    log_info "Next steps:"
    log_info "  1. Run: sudo microvm generate"
    log_info "  2. Rebuild NixOS: sudo nixos-rebuild switch"
    
  else
    log_error "Could not find 'microvm.vms = {' in $NIX_FILE"
    log_info "The file may be corrupted. Try: sudo microvm init"
    exit 1
  fi
}

# Remove a MicroVM
cmd_remove() {
  check_root
  
  if [[ $# -lt 1 ]]; then
    log_error "Usage: microvm remove <name>"
    exit 1
  fi
  
  local name="$1"
  
  if [[ ! -f "$NIX_FILE" ]]; then
    log_error "MicroVM configuration not found at $NIX_FILE"
    exit 1
  fi
  
  if ! grep -q "${name} = {" "$NIX_FILE" 2>/dev/null; then
    log_error "MicroVM '$name' not found"
    exit 1
  fi
  
  # Create backup
  cp "$NIX_FILE" "${NIX_FILE}.backup.$(date +%Y%m%d%H%M%S)"
  
  # Remove the VM block using awk
  # This needs to handle multi-line blocks properly
  local temp_file
  temp_file=$(mktemp)
  
  awk -v vm="$name" '
    /^    vm = \{/ { 
      if ($2 == vm " = {") {
        in_block = 1
        next
      }
    }
    in_block {
      # Count braces to find end of block
      brace_count = 0
      for (i = 1; i <= length($0); i++) {
        c = substr($0, i, 1)
        if (c == "{") brace_count++
        if (c == "}") brace_count--
      }
      if (brace_count < 0 || (brace_count == 0 && $0 ~ /\};$/)) {
        in_block = 0
      }
      next
    }
    { print }
  ' "$NIX_FILE" > "$temp_file"
  
  mv "$temp_file" "$NIX_FILE"
  
  log_success "Removed MicroVM '$name' from $NIX_FILE"
  log_info "A backup was created before removal"
  log_info "Next steps:"
  log_info "  1. Run: sudo nixos-rebuild switch"
}

# List all MicroVMs
cmd_list() {
  if [[ ! -f "$NIX_FILE" ]]; then
    log_info "No MicroVM configuration found at $NIX_FILE"
    log_info "Run 'sudo microvm init' to create one"
    exit 0
  fi
  
  echo "=== MicroVMs in $NIX_FILE ==="
  echo ""
  
  # Extract VM names and basic info
  local vms
  vms=$(grep -E "^\s+[a-zA-Z][a-zA-Z0-9_-]*\s*=\s*{" "$NIX_FILE" | grep -v "microvm.vms" | sed 's/ *= *{.*//' | sed 's/^[[:space:]]*//' || true)
  
  if [[ -z "$vms" ]]; then
    log_info "No MicroVMs defined yet"
    log_info "Add one with: sudo microvm add <name> --ip <ip>"
    exit 0
  fi
  
  printf "%-20s %-15s %-40s %-10s\n" "NAME" "MAC" "FLAKE" "AUTOSTART"
  printf "%-20s %-15s %-40s %-10s\n" "----" "---" "-----" "---------"
  
  while IFS= read -r vm_name; do
    [[ -z "$vm_name" ]] && continue
    
    # Extract flake
    local flake
    flake=$(grep -A 20 "^\s*${vm_name}\s*=\s*{" "$NIX_FILE" | grep "flake = " | head -1 | sed 's/.*flake = "\(.*\)";.*/\1/' || echo "N/A")
    
    # Extract mac
    local mac
    mac=$(grep -A 30 "^\s*${vm_name}\s*=\s*{" "$NIX_FILE" | grep "mac = " | head -1 | sed 's/.*mac = "\(.*\)";.*/\1/' || echo "auto")
    
    # Check autostart
    local autostart
    if grep -A 30 "^\s*${vm_name}\s*=\s*{" "$NIX_FILE" | grep -q "autostart = false"; then
      autostart="no"
    else
      autostart="yes"
    fi
    
    # Truncate long flakes
    if [[ ${#flake} -gt 37 ]]; then
      flake="${flake:0:34}..."
    fi
    
    printf "%-20s %-15s %-40s %-10s\n" "$vm_name" "$mac" "$flake" "$autostart"
  done <<< "$vms"
  
  echo ""
  echo "Total: $(echo "$vms" | wc -l | tr -d ' ') MicroVM(s)"
}

# Generate configuration (validate and show what will be applied)
cmd_generate() {
  if [[ ! -f "$NIX_FILE" ]]; then
    log_error "No MicroVM configuration found at $NIX_FILE"
    log_info "Run 'sudo microvm init' to create one"
    exit 1
  fi
  
  log_info "Validating Nix syntax..."
  if nix-instantiate --parse "$NIX_FILE" >/dev/null 2>&1; then
    log_success "Nix syntax is valid"
  else
    log_error "Invalid Nix syntax in $NIX_FILE"
    log_info "Run 'nix-instantiate --parse $NIX_FILE' for details"
    exit 1
  fi
  
  echo ""
  echo "=== Generated Configuration Preview ==="
  echo ""
  echo "File: $NIX_FILE"
  echo ""
  
  # Show the microvm.vms section
  awk '
    /^  microvm\.vms = \{/ { in_vms = 1; print; next }
    in_vms && /^  };$/ { print; in_vms = 0; next }
    in_vms { print }
  ' "$NIX_FILE"
  
  echo ""
  log_info "To apply: sudo nixos-rebuild switch"
}

# Edit a MicroVM (interactive)
cmd_edit() {
  check_root
  
  if [[ $# -lt 1 ]]; then
    log_error "Usage: microvm edit <name>"
    exit 1
  fi
  
  local name="$1"
  
  if [[ ! -f "$NIX_FILE" ]]; then
    log_error "MicroVM configuration not found"
    exit 1
  fi
  
  if ! grep -q "${name} = {" "$NIX_FILE" 2>/dev/null; then
    log_error "MicroVM '$name' not found"
    exit 1
  fi
  
  # Extract current values
  log_info "Current configuration for '$name':"
  awk -v vm="$name" '
    $0 ~ "^    " vm " = {" { in_block = 1; print; next }
    in_block && /^    };/ { print; in_block = 0; next }
    in_block { print }
  ' "$NIX_FILE"
  
  log_info "To edit, use your preferred editor:"
  log_info "  sudo $EDITOR $NIX_FILE"
  log_info ""
  log_info "Or remove and re-add:"
  log_info "  sudo microvm remove $name"
  log_info "  sudo microvm add $name [new options]"
}

# Show help
cmd_help() {
  cat << 'EOF'
Usage: microvm [command] [args]

Manage MicroVM definitions in Nix format. Generates type-safe Nix
configuration instead of fragile YAML parsing.

Commands:
  init                    Initialize microvm.nix configuration file
  add <name> [options]    Add a new MicroVM definition
  remove <name>           Remove a MicroVM definition
  list                    List all defined MicroVMs
  generate                Validate and preview configuration
  edit <name>             Show current config for editing
  help                    Show this help message

Add Options:
  --ip <ip|octet>         IP address (e.g., 192.168.83.16 or just 16)
  --flake <flake>         Full flake reference (default: .#microvm.nixosConfigurations.<name>)
  --mac <mac>             Custom MAC address (default: auto-generated)
  --no-autostart          Don't start VM on boot (default: autostart enabled)
  --memory <mb>           Memory in MB (default: 1024)
  --vcpus <n>             Number of vCPUs (default: 2)

Environment:
  MICROVM_NIX_FILE        Path to microvm.nix file (default: /etc/nixos/microvms.nix)
  MICROVM_DEBUG           Set to 1 for debug output

Examples:
  # Initialize configuration
  sudo microvm init

  # Add MicroVM with specific IP
  sudo microvm add openclaw --ip 192.168.83.16

  # Add with just the last octet (expands to 192.168.83.15)
  sudo microvm add matrix --ip 15

  # Add with external flake reference
  sudo microvm add myapp --ip 20 --flake github:user/repo#microvm.nixosConfigurations.myapp

  # List all MicroVMs
  microvm list

  # Remove a MicroVM
  sudo microvm remove openclaw

  # Validate and preview
  sudo microvm generate

Integration:
  Add this to your system configuration.nix:
    imports = [ /etc/nixos/microvms.nix ];

  Or use the microvm-host role which includes it automatically.

Workflow:
  1. sudo microvm init                    # First time setup
  2. sudo microvm add <name> --ip <ip>    # Add VMs
  3. microvm list                         # Review
  4. sudo microvm generate                # Validate
  5. sudo nixos-rebuild switch            # Apply

File: /etc/nixos/microvms.nix
EOF
}

# Main dispatch
case "${1:-help}" in
  init)
    cmd_init
    ;;
  add)
    shift
    cmd_add "$@"
    ;;
  remove)
    shift
    cmd_remove "$@"
    ;;
  list)
    cmd_list
    ;;
  generate)
    cmd_generate
    ;;
  edit)
    shift
    cmd_edit "$@"
    ;;
  help|--help|-h)
    cmd_help
    ;;
  *)
    log_error "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
